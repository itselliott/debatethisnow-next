# DebateThis — Next.js rewrite — environment variables.
#
# Copy this file to .env.local for local dev. Production values live in
# Fly secrets (`fly secrets set KEY=...`). NEVER commit .env or .env.local.
#
# Cross-cutting reminder: cookie names AND the JWT secret MUST match the
# Python app's so a user signed in on one can flip to the other without
# re-logging in. See MIGRATION_PARITY.md § 2.

# ---- Runtime ----
NODE_ENV=development
HOSTNAME=0.0.0.0
PORT=3000
# Comma-separated allowlist used for CORS + Socket.IO origin checks.
# In dev a wildcard `*` is fine; in prod the validator refuses wildcard.
CORS_ORIGINS=http://localhost:3000

# ---- Database (Neon Postgres) ----
# Same value as the Python app. Append ?sslmode=require for non-localhost.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ---- Auth (must match Python) ----
# 48-byte random secret. Generate: `node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"`
# Critical: MUST match the Python app's JWT_SECRET_KEY so tokens minted by
# either app are accepted by both during cutover.
JWT_SECRET_KEY=replace-with-the-actual-value-from-the-python-fly-secrets
# Salt for IP hashing (vote sockpuppet dedup + audit logs). MUST match
# the Python app's SECRET_KEY for cross-app hash compatibility.
SECRET_KEY=replace-with-the-actual-value-from-the-python-fly-secrets
# Token TTLs (defaults match Python).
JWT_ACCESS_TOKEN_HOURS=1
JWT_REFRESH_TOKEN_DAYS=30

# ---- OAuth providers ----
# Set both ID + SECRET for each provider you want enabled. The login UI
# only renders buttons for providers with both keys configured. Callback
# URLs registered with each provider must include
# https://debatethisnow.com/api/auth/oauth/<provider>/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ---- House-bot brains (server-side LLM dispatch) ----
# Each is optional; unconfigured providers fall through to canned templates.
# Free tiers (as of 2026):
#   Groq:     https://console.groq.com
#   Google:   https://aistudio.google.com
#   Mistral:  https://console.mistral.ai
#   Cerebras: https://cloud.cerebras.ai
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-70b

# ---- Optional LLM debate scorer (Claude-based) ----
# When ANTHROPIC_API_KEY is set AND admin enables it in /admin, final
# debate scoring uses Claude instead of the heuristic in scoring_service.
ANTHROPIC_API_KEY=

# ---- Game-tuning knobs (defaults match Python) ----
ELO_K_FACTOR=32
MATCH_ELO_WINDOW=200
STALE_DEBATE_MINUTES=60
PREP_SECONDS=30
VOTING_WINDOW_SECONDS=15
ROUND_OPENING_SECONDS=300
ROUND_REBUTTAL_SECONDS=180
ROUND_CLOSING_SECONDS=180
MAX_ARGUMENT_WORDS=800
MAX_ARGUMENT_BYTES=8000
DISCONNECT_FORFEIT_SECONDS=90

# ---- Rate limits (Flask-Limiter syntax: "N per period") ----
RATELIMIT_AUTH=10 per minute
RATELIMIT_REPORTS=20 per hour
RATELIMIT_VOTES=60 per minute
RATELIMIT_DEFAULT=300 per minute

# ---- Ads (off until ADSENSE_CLIENT_ID is set) ----
ADSENSE_CLIENT_ID=
ADSENSE_SLOT_BLOG_HEADER=
ADSENSE_SLOT_BLOG_MID=
ADSENSE_SLOT_BLOG_FOOTER=
ADSENSE_SLOT_BLOG_INDEX=
# Pipe-separated list of extra ads.txt seller lines.
EXTRA_ADS_TXT_LINES=

# ---- Observability (optional) ----
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_ENVIRONMENT=development

# ---- Dev-only ----
# Surfaces the bot-model picker on /settings.
DEV_MODE=0
